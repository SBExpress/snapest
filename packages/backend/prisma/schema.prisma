// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Company {
  id                String      @id @default(cuid())
  name              String
  email             String      @unique
  status            String      @default("active")
  subscriptionTier  String      @default("free")
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  users             User[]
  jobs              Job[]
  materials         Material[]
  settings          Settings?
}

model User {
  id                String      @id @default(cuid())
  email             String
  password          String
  name              String
  role              String      @default("user")
  status            String      @default("active")
  companyId         String
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  company           Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([email, companyId])
}

model Job {
  id                String      @id @default(cuid())
  name              String
  description       String?
  status            String      @default("draft")
  companyId         String
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  company           Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model Material {
  id                String      @id @default(cuid())
  itemNumber        String
  description       String
  unit              String
  basePrice         Float
  laborLevel1Hours  Float
  laborLevel2Hours  Float
  laborLevel3Hours  Float
  category          String
  companyId         String
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  company           Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([itemNumber, companyId])
  @@index([companyId])
}

model Settings {
  id                        String    @id @default(cuid())
  companyId                 String    @unique
  laborLevel1Name           String    @default("Apprentice")
  laborLevel2Name           String    @default("Journeyman")
  laborLevel3Name           String    @default("Foreman")
  laborLevel1Rate           Float     @default(25.00)
  laborLevel2Rate           Float     @default(45.00)
  laborLevel3Rate           Float     @default(65.00)
  laborBurdenPercent        Float     @default(30)
  materialSalesTaxPercent   Float     @default(6.625)
  materialOverheadPercent   Float     @default(15)
  materialProfitPercent     Float     @default(12)
  laborOverheadPercent      Float     @default(15)
  laborProfitPercent        Float     @default(12)
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  company                   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
}
