generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Company {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  status        String   @default("active")
  subscriptionTier String @default("starter")

  users         User[]
  materials     Material[]
  assemblies    Assembly[]
  estimates     Estimate[]
  settings      Settings?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
}

model User {
  id            String   @id @default(cuid())
  email         String
  password      String
  name          String
  role          String   @default("estimator")
  status        String   @default("active")

  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([email, companyId])
  @@index([companyId])
}

model Material {
  id            String   @id @default(cuid())
  itemNumber    String
  description   String
  unit          String
  basePrice     Decimal

  laborLevel1Hours Decimal?
  laborLevel2Hours Decimal?
  laborLevel3Hours Decimal?

  category      String   @default("General")
  supplier      String?
  isActive      Boolean  @default(true)
  isTemporary   Boolean  @default(false)

  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  estimateLineItems EstimateLineItem[]
  assemblyLineItems AssemblyLineItem[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([itemNumber, companyId])
  @@index([companyId])
  @@index([isTemporary])
}

model Assembly {
  id            String   @id @default(cuid())
  name          String
  description   String?
  category      String   @default("General")
  isActive      Boolean  @default(true)
  isTemporary   Boolean  @default(false)

  totalCost     Decimal  @default(0)

  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  lineItems     AssemblyLineItem[]
  estimateLineItems EstimateLineItem[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([companyId])
  @@index([isTemporary])
}

model AssemblyLineItem {
  id            String   @id @default(cuid())

  assemblyId    String
  assembly      Assembly @relation(fields: [assemblyId], references: [id], onDelete: Cascade)

  materialId    String
  material      Material @relation(fields: [materialId], references: [id], onDelete: Restrict)

  quantityFormula String?
  quantityValue Decimal

  laborLevel1Hours Decimal?
  laborLevel2Hours Decimal?
  laborLevel3Hours Decimal?

  lineTotal     Decimal  @default(0)

  orderIndex    Int      @default(0)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([assemblyId])
  @@index([materialId])
}

model Estimate {
  id            String   @id @default(cuid())
  estimateNumber String
  projectName   String
  customerGC    String
  address       String?
  scopeSummary  String?
  bidDueDate    DateTime?
  status        String   @default("draft")
  notes         String?

  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  lineItems     EstimateLineItem[]
  additionalCosts AdditionalCost[]

  laborLevel1Rate Decimal?
  laborLevel2Rate Decimal?
  laborLevel3Rate Decimal?
  laborBurdenPercent Decimal?

  materialOverheadPercent Decimal?
  materialProfitPercent Decimal?
  laborOverheadPercent Decimal?
  laborProfitPercent Decimal?

  salesTaxPercent Decimal?
  taxCalculationMode String? @default("modeA")

  totalMaterialCost Decimal @default(0)
  totalLaborCost Decimal @default(0)
  totalTax       Decimal  @default(0)
  totalAdditionalCosts Decimal @default(0)
  finalSellPrice Decimal  @default(0)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([estimateNumber, companyId])
  @@index([companyId])
  @@index([status])
  @@index([createdAt])
}

model EstimateLineItem {
  id            String   @id @default(cuid())

  estimateId    String
  estimate      Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)

  materialId    String?
  material      Material? @relation(fields: [materialId], references: [id], onDelete: SetNull)

  assemblyId    String?
  assembly      Assembly? @relation(fields: [assemblyId], references: [id], onDelete: SetNull)

  quantityFormula String?
  quantityValue Decimal
  unit          String

  materialPricePerUnit Decimal

  laborLevel1Hours Decimal @default(0)
  laborLevel2Hours Decimal @default(0)
  laborLevel3Hours Decimal @default(0)

  materialAdjustmentPercent Decimal @default(0)
  laborAdjustmentPercent Decimal @default(0)

  materialLineTotal Decimal @default(0)
  laborLineTotal Decimal @default(0)
  markup          Decimal  @default(0)
  sellingPrice    Decimal  @default(0)

  comment         String?

  orderIndex      Int      @default(0)

  source          String   @default("manual")
  isTemporary     Boolean  @default(false)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([estimateId])
  @@index([materialId])
  @@index([assemblyId])
}

model AdditionalCost {
  id            String   @id @default(cuid())
  description   String
  amount        Decimal
  applyOHnP     Boolean  @default(true)

  estimateId    String
  estimate      Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([estimateId])
}

model Settings {
  id            String   @id @default(cuid())

  companyId     String   @unique
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  laborLevel1Name String @default("Level 1")
  laborLevel2Name String @default("Level 2")
  laborLevel3Name String @default("Level 3")

  laborLevel1Rate Decimal @default(0)
  laborLevel2Rate Decimal @default(0)
  laborLevel3Rate Decimal @default(0)

  laborBurdenPercent Decimal @default(30)
  numberOfLaborLevels Int @default(3)

  materialSalesTaxPercent Decimal @default(0)
  taxCalculationMode String @default("modeA")

  materialOverheadPercent Decimal @default(15)
  materialProfitPercent Decimal @default(12)
  laborOverheadPercent Decimal @default(15)
  laborProfitPercent Decimal @default(12)
  applyOHPToAdditionalCosts Boolean @default(true)

  showPerLineUnitPrice Boolean @default(false)
  showRunningFinalPrice Boolean @default(false)
  unitPriceIncludesAdditionalCosts Boolean @default(false)

  miscMaterialPercent Decimal @default(7)
  miscMaterialEnabled Boolean @default(false)

  copyTakeoffPriceSource String @default("live")
  copyTakeoffIncludeTemporaryItems Boolean @default(false)
  copyTakeoffCopyCloseoutSettings Boolean @default(false)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
