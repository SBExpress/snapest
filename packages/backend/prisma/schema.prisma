generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Company {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  status        String   @default("active")
  subscriptionTier String @default("starter")

  users         User[]
  materials     Material[]
  assemblies    Assembly[]
  estimates     Estimate[]
  settings      Settings?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
}

model User {
  id            String   @id @default(cuid())
  email         String
  password      String
  name          String
  role          String   @default("estimator")
  status        String   @default("active")

  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([email, companyId])
  @@index([companyId])
}

model Material {
  id            String   @id @default(cuid())
  itemNumber    String
  description   String
  unit          String
  basePrice     Decimal  @db.Decimal(10, 2)

  laborLevel1Hours Decimal? @db.Decimal(8, 4)
  laborLevel2Hours Decimal? @db.Decimal(8, 4)
  laborLevel3Hours Decimal? @db.Decimal(8, 4)

  category      String   @default("General")
  supplier      String?
  isActive      Boolean  @default(true)
  isTemporary   Boolean  @default(false)

  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  estimateLineItems EstimateLineItem[]
  assemblyLineItems AssemblyLineItem[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([itemNumber, companyId])
  @@index([companyId])
  @@index([isTemporary])
}

model Assembly {
  id            String   @id @default(cuid())
  name          String
  description   String?
  category      String   @default("General")
  isActive      Boolean  @default(true)
  isTemporary   Boolean  @default(false)

  totalCost     Decimal  @db.Decimal(12, 2) @default(0)

  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  lineItems     AssemblyLineItem[]
  estimateLineItems EstimateLineItem[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([companyId])
  @@index([isTemporary])
}

model AssemblyLineItem {
  id            String   @id @default(cuid())

  assemblyId    String
  assembly      Assembly @relation(fields: [assemblyId], references: [id], onDelete: Cascade)

  materialId    String
  material      Material @relation(fields: [materialId], references: [id], onDelete: Restrict)

  quantityFormula String?
  quantityValue Decimal  @db.Decimal(10, 4)

  laborLevel1Hours Decimal? @db.Decimal(8, 4)
  laborLevel2Hours Decimal? @db.Decimal(8, 4)
  laborLevel3Hours Decimal? @db.Decimal(8, 4)

  lineTotal     Decimal  @db.Decimal(12, 2) @default(0)

  orderIndex    Int      @default(0)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([assemblyId])
  @@index([materialId])
}

model Estimate {
  id            String   @id @default(cuid())
  estimateNumber String
  projectName   String
  customerGC    String
  address       String?
  scopeSummary  String?
  bidDueDate    DateTime?
  status        String   @default("draft")
  notes         String?

  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  lineItems     EstimateLineItem[]
  additionalCosts AdditionalCost[]

  laborLevel1Rate Decimal? @db.Decimal(10, 2)
  laborLevel2Rate Decimal? @db.Decimal(10, 2)
  laborLevel3Rate Decimal? @db.Decimal(10, 2)
  laborBurdenPercent Decimal? @db.Decimal(5, 2)

  materialOverheadPercent Decimal? @db.Decimal(5, 2)
  materialProfitPercent Decimal? @db.Decimal(5, 2)
  laborOverheadPercent Decimal? @db.Decimal(5, 2)
  laborProfitPercent Decimal? @db.Decimal(5, 2)

  salesTaxPercent Decimal? @db.Decimal(5, 2)
  t
cat > .env << 'EOF'
PORT=3000
NODE_ENV=development
DATABASE_URL=file:./dev.db
API_BASE_URL=http://localhost:3000/api
LOG_LEVEL=info
JWT_SECRET=your-secret-key-here-change-in-production
