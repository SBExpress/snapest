{
  "name": "snapest-backend",
  "version": "0.1.0",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest",
    "lint": "eslint src --ext ts",
    "type-check": "tsc --noEmit",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "body-parser": "^1.20.2",
    "@prisma/client": "^5.4.0",
    "joi": "^17.11.0",
    "date-fns": "^2.30.0",
    "decimal.js": "^10.4.3",
    "dotenv": "^16.3.1",
    "jsonwebtoken": "^9.1.0"
  },
  "devDependencies": {
    "typescript": "^5.2.0",
    "@types/express": "^4.17.20",
    "@types/node": "^20.5.0",
    "tsx": "^3.14.0",
    "eslint": "^8.48.0",
    "@typescript-eslint/parser": "^6.4.0",
    "@typescript-eslint/eslint-plugin": "^6.4.0",
    "vitest": "^0.34.0",
    "prisma": "^5.4.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
