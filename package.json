{
  "name": "snapest",
  "version": "0.1.0",
  "description": "SnapEst - Keyboard-first estimating software for electrical contractors",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "setup": "npm install && npm run build"
  },
  "devDependencies": {
    "turbo": "^1.10.12",
    "prettier": "^3.0.0",
    "eslint": "^8.48.0",
    "typescript": "^5.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
